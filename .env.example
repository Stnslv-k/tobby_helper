# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ollama (используется нативная Ollama на хосте)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=ollama-local
OLLAMA_MODEL=llama3.2:3b

# Whisper
WHISPER_MODEL=small
WHISPER_LANGUAGE=ru

# Google Calendar OAuth
GOOGLE_CREDENTIALS_FILE=/app/credentials/credentials.json
GOOGLE_TOKEN_FILE=/app/credentials/token.json
# Публичный адрес сервера для OAuth-колбэка (без слэша в конце)
# Пример: http://123.456.78.90:8080 или https://mybot.example.com
OAUTH_PUBLIC_HOST=http://YOUR_VPS_IP:8080
OAUTH_PORT=8080

# Notion (опционально — можно настроить через /setup_notion в боте)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Путь к файлу динамического конфига (токены, сохранённые через бот)
USER_CONFIG_FILE=/app/credentials/user_config.json
