TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_IDS=your_telegram_numeric_id_here  # несколько через запятую: 111,222,333

ASANA_PAT=your_asana_personal_access_token
ASANA_WORKSPACE_GID=your_asana_workspace_gid

# LLM: use local Ollama (default) or remote OpenAI
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://172.20.0.1:11434
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_API_KEY=   # only if your Ollama requires auth

# Uncomment to switch to OpenAI:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

WHISPER_MODEL=small
WHISPER_LANGUAGE=ru

DEADLINE_NOTIFY_DAYS=1,2
NOTIFY_TIME=09:00
RATE_LIMIT_SECONDS=3
